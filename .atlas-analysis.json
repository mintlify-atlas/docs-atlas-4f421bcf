  "keyFeatures": [
    "Role-based access control for Admins, Students, and Coordinators",
    "Weekly schedule browser with day and level filtering",
    "Student enrollment and class registration management",
    "Payment reporting, validation, and accounts-receivable tracking",
    "Attendance recording with present/absent/late/justified statuses",
    "Injury and recovery tracking per student",
    "Multi-location (sede) and multi-court (cancha) support",
    "Training level catalog with monthly pricing",
    "Class rescheduling and makeup session management",
    "Admin publications and news feed for students",
    "Guest pass management",
    "Benefit and discount system",
    "Export reports to Excel (xlsx)"
  ],
